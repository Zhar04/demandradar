# ============================================================
# DemandRadar — все секреты и режимы. Скопируй в .env и заполни
# то, что есть. ОТСУТСТВИЕ ключа = коннектор работает в MOCK-
# режиме на фикстурах, ядро при этом полностью работоспособно.
# ============================================================

# --- Общее ---
# Окружение: dev | prod
DR_ENV=dev
# Путь к БД SQLite (по умолчанию data/demandradar.db)
DR_DB_PATH=data/demandradar.db
# Уровень логирования: DEBUG | INFO | WARNING
DR_LOG_LEVEL=INFO

# Включить ЖИВОЙ скрапинг для источников без API-ключей
# (mitwork, med/fms.ecc, mp.kz). Пусто = mock на фикстурах.
# Включай осознанно: живой обход уважает Crawl-delay площадок.
DR_SCRAPE_LIVE=

# --- Госзакуп (формализованный спрос) ---
# Токен открытого API goszakup.gov.kz (личный кабинет -> API).
# Пусто = mock-режим на фикстурах.
GOSZAKUP_TOKEN=

# --- Telegram-уведомления ---
# Токен бота от @BotFather и chat_id получателя.
# Пусто = уведомления печатаются в консоль (dry-run).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Обогащение контактами (Этап 2) ---
# Statsnet / Kompra / Adata — пока mock, живые ключи добавим позже.
STATSNET_TOKEN=
KOMPRA_TOKEN=
ADATA_TOKEN=

# --- Латентный спрос (Этап 6) ---
# Яндекс.Директ (Wordstat) OAuth-токен.
YANDEX_DIRECT_TOKEN=
# hh.ru/hh.kz API (для watchlist-вакансий, Этап 5) — анонимный доступ
# возможен, токен повышает лимиты.
HH_TOKEN=

# --- data.egov.kz (опережающий спрос, Этап 5) ---
DATA_EGOV_APIKEY=

# --- ИИ-слой (ОПЦИОНАЛЬНО, по умолчанию ВЫКЛЮЧЕН) ---
# Провайдер: null | ollama | claude_code
DR_LLM_PROVIDER=null
# Модель Ollama (если провайдер ollama). Рекомендация: qwen3:8b
# (баланс ума/скорости); слабое железо -> qwen3:4b.
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434
